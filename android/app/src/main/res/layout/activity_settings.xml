<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1117"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Endereco do servidor"
        android:textColor="#8b949e"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/editUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edit_bg"
        android:textColor="#c9d1d9"
        android:textColorHint="#4a5568"
        android:hint="http://192.168.1.10/pcstatus"
        android:fontFamily="monospace"
        android:textSize="15sp"
        android:padding="14dp"
        android:inputType="textUri"
        android:singleLine="true"
        android:imeOptions="actionDone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Endereco completo sem barra no final.\nExemplo: http://192.168.1.10/pcstatus"
        android:textColor="#8b949e"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="SALVAR E CONECTAR"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        android:background="@drawable/btn_green"
        android:textColor="#ffffff" />

</LinearLayout>
